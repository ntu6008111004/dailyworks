# Server Configuration
PORT=3001
NODE_ENV=development
API_KEY=generate_a_very_secure_random_string_here
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false

# AI Assistant (server-only; rotate any key that was ever exposed in frontend code)
AI_SESSION_SECRET=generate_at_least_32_random_characters_here
THAILLM_API_KEY=replace_with_rotated_thaillm_key
THAILLM_API_URL=https://thaillm.or.th/api/v1/chat/completions
# Set true only when the provider has no HTTPS endpoint. This leaves the
# backend-to-provider hop vulnerable to network interception.
THAILLM_ALLOW_INSECURE_HTTP=false
THAILLM_MODEL=pathumma-thaillm-qwen3-8b-think-3.0.0
THAILLM_TIMEOUT_MS=45000
THAILLM_EXPOSE_THINKING=false
AI_RATE_LIMIT_PER_SECOND=5
AI_RATE_LIMIT_PER_MINUTE=60
# Maximum scoped rows used only to calculate dashboard-style AI summaries.
AI_MAX_METRIC_ROWS=5000
# Optional: more reliable web/news search than the DuckDuckGo Instant fallback.
# Brave currently provides recurring free API credit; keep this server-side.
BRAVE_SEARCH_API_KEY=

# MongoDB Root Configuration (For docker-compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=password123

# MongoDB Connection URI
MONGODB_URI=mongodb://admin:password123@db:27017/dailywork?authSource=admin

# Mongo Express UI Credentials
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASS=adminpass123

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

