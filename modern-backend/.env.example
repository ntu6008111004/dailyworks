# Server Configuration
PORT=3001
NODE_ENV=development
API_KEY=generate_a_very_secure_random_string_here

# MongoDB Root Configuration (For docker-compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=password123

# MongoDB Connection URI
MONGODB_URI=mongodb://admin:password123@db:27017/dailywork?authSource=admin

# Mongo Express UI Credentials
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASS=adminpass123

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

