VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional direct ThaiLLM fallback. VITE_ values are intentionally exposed to
# the browser, so use this only for a provider key that is safe to publish.
VITE_THAILLM_API_KEY=your_public_thaillm_key
VITE_THAILLM_API_URL=/api/thaillm/chat/completions

# Production: set this to the public HTTPS URL of modern-backend plus /api/ai.
# Leave unset in local development to use the Vite /api/ai proxy.
VITE_AI_API_BASE_URL=https://api.example.com/api/ai

# Local Vite proxy target (read by vite.config.js, not shipped as a browser secret).
VITE_AI_PROXY_TARGET=http://localhost:3001
